<div class="main-wrapper">
    <div class="site-header">
        <h1 class="site-title">Gallery</h1>
        <p class="site-tagline">The official home of The Bob SMP</p>
    </div>

    <div class="card">
        <h2>Community builds & screenshots</h2>
        <p>
            Upload your images to <span class="code">assets/images/</span> and they will appear here.
        </p>
    </div>

    <div class="card gallery-grid">

        <!-- Example images — replace with your own filenames -->
        <div class="gallery-item">
            <img src="assets/images/spawn.png" alt="Spawn" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
        </div>

        <div class="gallery-item">
            <img src="assets/images/shopping_district.jpg" alt="Shopping District" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
        </div>

        <div class="gallery-item">
            <img src="assets/images/nether_hub.png" alt="Nether Hub" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
        </div>

        <!-- Add more images by copying this block:
        <div class="gallery-item">
            <img src="assets/images/YOURIMAGE.png" alt="Description" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
        </div>
        -->

    </div>
</div>

<footer class="footer">
    &copy; <span id="year"></span> The Bob SMP. All rights reserved.
</footer>

<script>
    document.getElementById('year').textContent = new Date().getFullYear();
</script>
